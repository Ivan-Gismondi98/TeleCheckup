<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TeleCheckup.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TeleCheckup.Views"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#0033FF" HeightRequest="150" Padding="20">
            <Label Text="TELE CHECKUP" TextColor="White" FontSize="22" FontAttributes="Bold" VerticalOptions="End" />
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate views:LoginPage}" Shell.NavBarIsVisible="False" Shell.FlyoutItemIsVisible="False" />
    
    <FlyoutItem Title="Home (Dashboard)" Route="DashboardPage">
        <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>

</Shell>