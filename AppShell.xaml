<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TeleCheckup.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:TeleCheckup.Views"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#0033FF" Padding="18" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
            <StackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                <Label Text="Benvenuto," TextColor="White" FontSize="12" />
                <Label Text="Mario Rossi" TextColor="White" FontSize="18" FontAttributes="Bold" />
                <Frame BackgroundColor="#EFFF00" Padding="6,2" CornerRadius="6" HasShadow="False" HorizontalOptions="Start">
                    <Label Text="RUOLO: PATIENT" FontSize="10" TextColor="#0B1220" />
                </Frame>
            </StackLayout>

            <Frame Grid.Row="0" Grid.Column="1" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="White" HorizontalOptions="End" VerticalOptions="Start">
                <Label Text="M" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#0033FF" />
            </Frame>

            <!-- small divider -->
            <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" Color="#E5E7EB" Margin="0,12,0,0" />
        </Grid>
    </Shell.FlyoutHeader>

    <ShellContent Route="LoginPage" ContentTemplate="{DataTemplate views:LoginPage}" Shell.NavBarIsVisible="False" Shell.FlyoutItemIsVisible="False" />

    <FlyoutItem Title="Profilo" Icon="icon_profile.png" Route="ProfilePage">
        <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
    </FlyoutItem>

    <FlyoutItem Title="Home" Route="DashboardPage">
        <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" />
    </FlyoutItem>

    <Shell.FlyoutFooter>
        <StackLayout Padding="12" Spacing="8">
            <Label Text="Versione App: 1.0.0" FontSize="12" TextColor="{StaticResource Gray500}" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Label Text="" />
                <Button Text="Logout" Clicked="OnLogoutClicked" BackgroundColor="Transparent" TextColor="#FF0033" Grid.Column="1" />
            </Grid>
        </StackLayout>
    </Shell.FlyoutFooter>

</Shell>