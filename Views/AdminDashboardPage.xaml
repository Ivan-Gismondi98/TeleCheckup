<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.AdminDashboardPage"
             Title="Dashboard Admin"
             BackgroundColor="{StaticResource Gray100}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            <!-- Top red system alert -->
            <Frame CornerRadius="12" BackgroundColor="{StaticResource ElectricRed}" Padding="12" HasShadow="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Text="🛡" Grid.Column="0" FontSize="20" TextColor="White" VerticalOptions="Center" />
                    <StackLayout Grid.Column="1" Spacing="2">
                        <Label Text="Sistema Bug" TextColor="White" FontAttributes="Bold" />
                        <Label Text="Nessun crash. 3 warning registrati." TextColor="White" FontSize="12" />
                    </StackLayout>
                    <Label Text="›" Grid.Column="2" TextColor="White" FontSize="20" VerticalOptions="Center" HorizontalOptions="End" />
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSystemBugClicked" />
                    </Frame.GestureRecognizers>
                </Grid>
            </Frame>

            <!-- Grid of admin cards -->
            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Frame Grid.Row="0" Grid.Column="0" CornerRadius="12" BackgroundColor="White" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="👥" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Gestione Utenti" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Sblocchi, Reset Password, Ruoli" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnManageUsersClicked" />
                        </Frame.GestureRecognizers>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" CornerRadius="12" BackgroundColor="White" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📄" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="CRUD Blog" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Categorie e Articoli Glob." FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCrudBlogClicked" />
                        </Frame.GestureRecognizers>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" CornerRadius="12" BackgroundColor="White" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="⚙️" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Permessi App" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Gestione accessi viste" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAppPermissionsClicked" />
                        </Frame.GestureRecognizers>
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" CornerRadius="12" BackgroundColor="White" Padding="16" HasShadow="True">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="📈" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Statistiche" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Uso e performance" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnStatisticsClicked" />
                        </Frame.GestureRecognizers>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
