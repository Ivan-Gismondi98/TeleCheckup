<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.AiAdvicePage"
             Title="Consiglio IA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Label x:Name="AreaLabel" Text="Area: --" FontSize="20" FontAttributes="Bold" />
            <Label Text="L'intelligenza artificiale ha valutato il sintomo come lieve/moderato. Ecco alcuni consigli:" FontSize="14" TextColor="{StaticResource Gray500}" />

            <Frame CornerRadius="12" BackgroundColor="White" Padding="12" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <Label Text="- Riposa la zona interessata" />
                    <Label Text="- Applica ghiaccio per 15-20 minuti" />
                    <Label Text="- Assumi farmaci da banco se necessario seguendo le indicazioni" />
                    <Label Text="- Se il dolore persiste oltre 48 ore contatta il medico" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Torna alla Home" Clicked="OnBack" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>