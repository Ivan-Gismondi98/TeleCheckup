<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.ChatPage"
             Title="Emergenza Medica">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Grid BackgroundColor="{StaticResource Primary}" Padding="12" RowSpacing="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Text="◀" BackgroundColor="Transparent" TextColor="White" Clicked="OnBackPressed" />
            <StackLayout Grid.Column="1" Spacing="2">
                <Label Text="Emergenza Medica" TextColor="White" FontAttributes="Bold" />
                <Label Text="Dottore In linea" TextColor="White" FontSize="12" />
                <Label x:Name="AreaLabel" Text="Chat - Area: --" TextColor="White" FontSize="12" />
            </StackLayout>
        </Grid>

        <!-- Messages / content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="12" Spacing="12">
                <!-- Messages list -->
                <CollectionView x:Name="MessagesList" HeightRequest="180">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="8" Margin="4" CornerRadius="8" BackgroundColor="{StaticResource Gray100}">
                                <Label Text="{Binding}" />
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- System card -->
                <Frame CornerRadius="8" Padding="12" BackgroundColor="White" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Sistema" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                        <Label Text="Il resoconto del Pharma Checker è stato allegato in PDF." FontSize="13" TextColor="{StaticResource Gray500}" />
                        <Frame CornerRadius="6" BackgroundColor="{StaticResource Gray100}" Padding="8">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="📄" />
                                <Label Text="report_sintomi.pdf" />
                            </HorizontalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </Frame>

                <!-- Doctor card -->
                <Frame CornerRadius="8" Padding="12" BackgroundColor="White" HasShadow="True">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Dottore" TextColor="{StaticResource Primary}" FontAttributes="Bold" />
                        <Label Text="Ho ricevuto il suo report. Clicchi sul link qui sotto per avviare una videochiamata immediata." FontSize="13" TextColor="{StaticResource Gray500}" />
                        <Button Text="Avvia Televisita" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="8" Clicked="OnStartTelevisit" />
                    </VerticalStackLayout>
                </Frame>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Input area fixed at bottom -->
        <Grid Grid.Row="2" Padding="10" BackgroundColor="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Frame CornerRadius="24" BackgroundColor="{StaticResource Gray100}" Padding="8" VerticalOptions="Center">
                <HorizontalStackLayout>
                    <Entry x:Name="MessageEntry" Placeholder="Scrivi un messaggio..." BackgroundColor="Transparent" />
                </HorizontalStackLayout>
            </Frame>
            <Button Grid.Column="1" Text="💬" WidthRequest="48" HeightRequest="48" CornerRadius="24" BackgroundColor="{StaticResource Primary}" TextColor="White" Clicked="OnSend" />
        </Grid>
    </Grid>

</ContentPage>