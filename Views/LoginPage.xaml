<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.LoginPage"
             BackgroundColor="#0033FF">

    <VerticalStackLayout VerticalOptions="Center" Padding="30" Spacing="25">
        <Label Text="TELE CHECKUP" FontSize="36" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
        <Label Text="La tua salute, ovunque tu sia." FontSize="16" TextColor="#E0E7FF" HorizontalOptions="Center" Margin="0,0,0,20"/>

        <Frame BackgroundColor="White" CornerRadius="20" Padding="25" HasShadow="True">
            <VerticalStackLayout Spacing="15">
                <Label Text="Accedi per continuare" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" HorizontalOptions="Center" Margin="0,0,0,10"/>
                
                <Button Text="Accedi come Paziente" BackgroundColor="#0033FF" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" Clicked="OnPatientClicked"/>
                <Button Text="Accedi come Medico" BackgroundColor="#EFFF00" TextColor="#1A1A1A" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" />
                <Button Text="Accedi come Admin" BackgroundColor="#FF0033" TextColor="White" CornerRadius="12" HeightRequest="50" FontAttributes="Bold" />
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>