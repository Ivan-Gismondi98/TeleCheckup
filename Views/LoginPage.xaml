<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.LoginPage"
             BackgroundColor="#0033FF">

    <VerticalStackLayout VerticalOptions="Center" Padding="30" Spacing="20">
        <!-- Icon -->
        <Frame WidthRequest="96" HeightRequest="96" CornerRadius="48" BackgroundColor="White" HorizontalOptions="Center" HasShadow="True">
            <Label Text="" HorizontalOptions="Center" VerticalOptions="Center" FontSize="36" TextColor="{StaticResource Primary}" />
        </Frame>

        <Label Text="TELE CHECKUP" Style="{StaticResource Headline}" />
        <Label Text="La tua salute, ovunque tu sia." Style="{StaticResource SubHeadline}" FontSize="14" />

        <Frame BackgroundColor="White" CornerRadius="20" Padding="20" HasShadow="True">
            <VerticalStackLayout Spacing="14">
                <Label Text="Accedi per continuare" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" HorizontalOptions="Center" />

                <Button Text="Accedi come Paziente" BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" HeightRequest="48" FontAttributes="Bold" Clicked="OnPatientClicked" />
                <Button Text="Accedi come Medico" BackgroundColor="{StaticResource NeonYellow}" TextColor="#1A1A1A" CornerRadius="20" HeightRequest="48" FontAttributes="Bold" Clicked="OnDoctorClicked" />
                <Button Text="Accedi come Admin" BackgroundColor="{StaticResource ElectricRed}" TextColor="White" CornerRadius="20" HeightRequest="48" FontAttributes="Bold" Clicked="OnAdminClicked" />

                <HorizontalStackLayout HorizontalOptions="Center" Padding="0,6,0,0">
                    <Label Text="Nuovo utente?" TextColor="White" />
                    <Label Text=" Registrati" TextColor="White" FontAttributes="Bold" TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnRegisterClicked" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Frame>
    </VerticalStackLayout>
</ContentPage>