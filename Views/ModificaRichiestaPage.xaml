<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.ModificaRichiestaPage"
             Title="Modifica Richiesta">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Modifica richiesta di visita" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <DatePicker x:Name="DataPicker" />
        <Picker x:Name="TipoVisitaPicker" Title="Tipo Visita" />
        <Entry x:Name="NoteEntry" Placeholder="Note aggiuntive" />
        <Button Text="Salva Modifiche" Clicked="OnSalvaModificheClicked" />
    </VerticalStackLayout>
</ContentPage>
