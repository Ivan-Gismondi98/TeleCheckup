<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.PatientDashboardPage"
             Title="Home"
             BackgroundColor="{StaticResource GrayBg}">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <Label Text="I tuoi servizi" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource ElectricBlue}" />

            <!-- Pharma Checker (La Chicca) -->
            <Frame BackgroundColor="#1A1A1A" CornerRadius="15" Padding="20" HasShadow="True">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnPharmaCheckerTapped" />
                </Frame.GestureRecognizers>
                <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label Text="💊" FontSize="30" />
                    <VerticalStackLayout>
                        <Label Text="Pharma Checker" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource NeonGreen}" />
                        <Label Text="Individua il dolore sul corpo" FontSize="14" TextColor="LightGray" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Frame>

            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" RowSpacing="15" ColumnSpacing="15">
                <!-- Televisita -->
                <Frame Grid.Row="0" Grid.Column="0" CornerRadius="15" HasShadow="True">
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTelevisitaTapped" />
                    </Frame.GestureRecognizers>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="🎥" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Televisita" FontAttributes="Bold" TextColor="{StaticResource ElectricBlue}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
                
                <!-- Visite ed esami -->
                <Frame Grid.Row="0" Grid.Column="1" CornerRadius="15" HasShadow="True">
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="📅" FontSize="30" HorizontalOptions="Center"/>
                        <Label Text="Visite" FontAttributes="Bold" TextColor="{StaticResource DarkText}" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>