<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.RegisterPage"
             Title="Registrazione Paziente">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Registrazione Paziente" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

            <Entry x:Name="NameEntry" Placeholder="Nome e Cognome" />
            <Entry x:Name="EmailEntry" Placeholder="Email" Keyboard="Email" />
            <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />
            <Entry x:Name="ConfirmPasswordEntry" Placeholder="Conferma Password" IsPassword="True" />

            <Button Text="Registrati" BackgroundColor="{StaticResource Primary}" TextColor="White" Clicked="OnRegisterSubmit" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>