<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.RichiestaVisitaPage"
             Title="Richiesta Visita">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Richiedi una visita" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <Picker x:Name="MedicoPicker" Title="Seleziona Medico" />
        <DatePicker x:Name="DataPicker" MinimumDate="2026-03-01" MaximumDate="2027-03-01" />
        <Picker x:Name="TipoVisitaPicker" Title="Tipo Visita" />
        <Entry x:Name="NoteEntry" Placeholder="Note aggiuntive" />
        <Button Text="Invia Richiesta" Clicked="OnInviaRichiestaClicked" />
    </VerticalStackLayout>
</ContentPage>
