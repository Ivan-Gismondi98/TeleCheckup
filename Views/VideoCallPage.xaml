<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="[http://schemas.microsoft.com/dotnet/2021/maui](http://schemas.microsoft.com/dotnet/2021/maui)"
             xmlns:x="[http://schemas.microsoft.com/winfx/2009/xaml](http://schemas.microsoft.com/winfx/2009/xaml)"
             x:Class="TeleCheckup.Views.VideoCallPage"
             Title="Televisita in corso"
             Shell.TabBarIsVisible="False">

    <Grid>
        <!-- Inserisci qui l'URL della tua web app che gestisce il WebRTC -->
        <WebView x:Name="VideoCallWebView" 
                 Source="[https://meet.jit.si/TeleCheckup_StanzaSicura_123](https://meet.jit.si/TeleCheckup_StanzaSicura_123)" 
                 HorizontalOptions="FillAndExpand" 
                 VerticalOptions="FillAndExpand" />
                 
        <!-- Tasto emergenza / chiudi -->
        <Button Text="Chiudi Chiamata" 
                BackgroundColor="{StaticResource ElectricRed}" 
                TextColor="White"
                CornerRadius="25"
                WidthRequest="200"
                HeightRequest="50"
                VerticalOptions="End" 
                Margin="0,0,0,30"
                Clicked="OnEndCallClicked" />
    </Grid>

</ContentPage>