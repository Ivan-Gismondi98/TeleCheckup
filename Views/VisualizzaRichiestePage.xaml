<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TeleCheckup.Views.VisualizzaRichiestePage"
             Title="Le tue richieste">
    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Le tue richieste di visita" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />
        <CollectionView x:Name="RichiesteCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BorderColor="Gray" CornerRadius="10" Padding="10" Margin="0,5">
                        <VerticalStackLayout>
                            <Label Text="{Binding MedicoNome}" FontAttributes="Bold" />
                            <Label Text="Data: {Binding Data}" />
                            <Label Text="Tipo: {Binding TipoVisita}" />
                            <Label Text="Stato: {Binding Stato}" />
                            <Label Text="Note: {Binding Note}" />
                            <HorizontalStackLayout Spacing="10">
                                <Button Text="Modifica" Clicked="OnModificaRichiestaClicked" CommandParameter="{Binding .}" />
                                <Button Text="Elimina" Clicked="OnEliminaRichiestaClicked" CommandParameter="{Binding .}" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>
